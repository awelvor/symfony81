

<div class="col col-6">
<table class="table table-sm table-hover">
        <thead>
            <tr>
               <th>Date</th>
                <th>Libelle</th>
                <th>Credit</th>
                <th>Debit</th>
                <th>Banque</th>
                <th>CBid</th>
                </tr>
        </thead>
        <tbody>
        {% for euro in euros22 %}
            <tr>
               <td>{{ euro.date }}</td>
                <td>{{ euro.libelle }}</td>
                {% if euro.credit > 0 %}<td class="text-end">{{ euro.credit |number_format(2,'.','') }}</td>{% else %}<td></td>{% endif %}
                {% if euro.debit > 0 %}<td class="text-end">{{ euro.debit |number_format(2,'.','') }}</td>{% else %}<td></td>{% endif %}
                <td>{{ euro.banque }}</td>
                <td>{{ euro.cbid }}</td>
                </tr>
        {% endfor %}
        </tbody>
    </table>
      </div>
 </div>
