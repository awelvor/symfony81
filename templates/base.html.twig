<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        
        
        {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        
    </head>
     <body class="bg-light">
    {% set year="now"|date("Y") %}
    {% set budget= "now"|format_datetime(locale='fr', pattern="MMMMYYYY") %}


<div class="container">
<nav class="navbar navbar-expand-sm bg-primary navbar-dark">
<ul class="navbar-nav">
<li class="nav-item"><a class="nav-link active" href="{{path('euros.budgets2',{'year':year,'budget':budget})}}">Budgets</a></li>
<li class="nav-item"><a class="nav-link active" href="{{path('euros.home')}}">Comptes</a></li>
<li class="nav-item"><a class="nav-link active" href="{{path('euros.create')}}">Newop</a></li>
<li class="nav-item"><a class="nav-link active" href="{{path('app_actifs_index')}}">Actifs</a></li>


<li class="nav-item"><a class="nav-link active" href="{{path('euros.cheques')}}">Cheques</a></li>
</ul> 
</nav>
</div>

{# templates/base.html.twig (ou directement dans votre page de contact) #}

<div class="container mt-3">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>
  


    <div class="container my-4">

    {% block body %}{% endblock %}
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
